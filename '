-- Return orders placed in June 2021.
-- avoiding using functions like month() and year() in order to make it sargeable
select
  OrderId,
  OrderDate,
  CustomerId,
  EmployeeId
from
  Sales.[Order]
where
  OrderDate >= '20210601'
    and
  OrderDate < '20210701'
order by
  OrderDate
GO

