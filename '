-- Inspecting the qualified names needed to query every table.
select
  s.schema_id as schema_id,
  s.name as schema_name,
  t.name as table_name,
  concat(s.name,'.',t.name) as qualified_name
from
  sys.schemas s
join
  sys.tables t
on
  s.schema_id = t.schema_id
GO

