-- (6) Explain the difference between the following two queries
-- 6.1
/*
 * SQL processes clauses in the following order:
 *  from > where > group by > having > select > order by
 * the first query asks
 *  'how many orders has each employee placed before 'date'?' 
 */
select
  EmployeeId,
  count(*) as numorders
from
  Sales.[Order]
where 
  orderdate < '20300101'
group by 
  EmployeeId;
GO

-- 6.2
/*
 * This query first groups rows by employees.
 * for each employee, it asks if the most recent order occured before 'date'
 */
select
  EmployeeId,
  Count(*) as numorders
From
  Sales.[Order]
group by 
  EmployeeId
having
  max(orderdate) < '20300101';
go
-- (7) Return the three ship countries with the highest average freight for orders placed in 2015.  
select
  top(3)
  ShipToCountry,
  avg(Freight) as AvgFreight
from
  Sales.[Order]
where
  OrderDate < '20160101'
    and
  OrderDate >= '20150101'
group by
  ShipToCountry
order by
  AvgFreight desc;
go

-- (8) calculate row numbers for orders based on order date ordering
-- (using order id as the tiebreaker)
-- for each customer separately
select
  top(2)
  CustomerId,
  OrderDate,
  OrderId,
  row_number() over (partition by CustomerId order by OrderDate, OrderId)
from
  Sales.[Order]
GO

-- (9) Figure out and return for each employee the gender based on
-- the title of courtesy: 
--  {Ms., Mrs.} = female, 
--  {Mr.} = Male, 
--  {Dr.} - Unknown
select
  EmployeeId,
  EmployeeFirstName,
  EmployeeLastName,
  EmployeeTitleOfCourtesy,
  Case
    when EmployeeTitleOfCourtesy in ('Ms.', 'Mrs.') then 'Female'
    when EmployeeTitleOfCourtesy in ('Mr.') then 'Male'
    when EmployeeTitleOfCourtesy in ('Dr.') then 'Unknown'
  end as gender
from
  HumanResources.Employee
order by
  EmployeeId
GO

