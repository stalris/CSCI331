-- (3) return employees with last name containing the letter 'e' at least 2 times.
select
  EmployeeId,
  EmployeeFirstName,
  EmployeeLastName
from
  HumanResources.Employee
where
  (
    len(EmployeeLastName) 
      - 
    len(replace(EmployeeLastName, 'e', ''))
  ) 
  >= 2  
order by
  EmployeeId
GO

